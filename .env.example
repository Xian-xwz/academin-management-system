# =============================================================================
# Dify 环境变量示例（复制为 .env 后填写真实值）
# 复制命令：copy .env.example .env   （PowerShell 可用 Copy-Item）
# =============================================================================

# -----------------------------------------------------------------------------
# 知识库（Dataset）服务 API — 批量上传 Markdown、维护文档时用
# 获取方式：Dify 控制台 → 知识库 → 右上角「服务 API」→ 查看 API 端点、创建 API 密钥
# 注意：此为「知识库 API Key」，与下方「应用 API Key」不是同一个
# -----------------------------------------------------------------------------
DIFY_KNOWLEDGE_API_BASE=https://api.dify.ai/v1
DIFY_DATASET_API_KEY=
DIFY_DATASET_ID=

# 可选：批量上传脚本并发请求数与知识库 API 请求速率。
# Dify 官方云端沙箱/低配额度建议保持 10 次/分钟，并发设为 1。
DIFY_UPLOAD_CONCURRENCY=3
DIFY_KNOWLEDGE_REQUESTS_PER_MINUTE=10

# 可选：如果知识库已在 Dify 控制台选择 Embedding 模型，下面两项可留空。
# 若要通过 API 指定，请填写 Dify「可用模型」中的模型名与供应商标识。
# 例如模型名可使用 text-embedding-v4；供应商标识以 Dify 控制台/服务 API 返回为准。
DIFY_EMBEDDING_MODEL=
DIFY_EMBEDDING_MODEL_PROVIDER=

# -----------------------------------------------------------------------------
# 应用（Chatflow / Agent）— FastAPI 调用对话、工作流时用
# 获取方式：应用发布页 → API 访问 → API 密钥
# -----------------------------------------------------------------------------
DIFY_APP_API_BASE=https://api.dify.ai/v1
DIFY_APP_API_KEY=
DIFY_APP_API_ID=
# 可选：接入正式版 Agent 时可使用独立变量；后端优先读取 DIFY_AGENT_TOKEN / dify_agent_token。
DIFY_AGENT_TOKEN=
DIFY_AGENT_ID=

# -----------------------------------------------------------------------------
# 知识卡片 Dify Workflow — 独立于学业问询 Agent
# -----------------------------------------------------------------------------
# 获取方式：知识卡片工作流应用 → API 访问 → API 密钥；工作流 ID 填应用/工作流标识。
# 后端优先调用 `/workflows/run`，若应用不是 workflow 会自动切到 `/chat-messages`。
# 当前知识卡片应用输入变量为 content、prompt；后端也会兼容发送 input_text、extra_prompt。
DIFY_KNOWLEDGE_CARD_API_BASE=https://api.dify.ai/v1
DIFY_KNOWLEDGE_CARD_API_KEY=
DIFY_KNOWLEDGE_CARD_WORKFLOW_ID=
DIFY_KNOWLEDGE_CARD_TIMEOUT_SECONDS=180

# -----------------------------------------------------------------------------
# Mock 动态器 — 学生登录后自动为论坛生成演示动态（可选）
# -----------------------------------------------------------------------------
# 开启后，学生登录会自动发布本专业相关帖子或评论；LLM 不可用时回退模板。
MOCK_DYNAMIC_ENABLED=true
MOCK_DYNAMIC_USE_LLM=true
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.6-flash
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# OpenClaw 受控工具接口 — 只允许服务器到服务器调用 /api/openclaw/*
# -----------------------------------------------------------------------------
# OpenClaw 请求需携带 Authorization: Bearer <OPENCLAW_TOOL_TOKEN>。
# OPENCLAW_ALLOWED_STUDENT_IDS 使用逗号分隔；生产环境不要使用 *，演示环境可临时使用。
OPENCLAW_TOOL_TOKEN=
OPENCLAW_ALLOWED_STUDENT_IDS=202211911001,202211921001,202211931001

# -----------------------------------------------------------------------------
# Dify Agent 正式版工具接口 — /api/agent-tools/*
# -----------------------------------------------------------------------------
# Dify Custom Tool 请求需携带 Authorization: Bearer <AGENT_TOOL_TOKEN>。
# 若未单独配置 AGENT_TOOL_TOKEN，后端会临时回退使用 OPENCLAW_TOOL_TOKEN，便于平滑迁移。
# agentSessionToken 由已登录用户调用 /api/agent-tools/sessions 获取，用于绑定当前用户权限。
AGENT_TOOL_TOKEN=
AGENT_SESSION_EXPIRE_MINUTES=120

# -----------------------------------------------------------------------------
# GitHub 私有仓库 — 服务器用 HTTPS 拉代码时（可选）
# -----------------------------------------------------------------------------
# 若使用 Personal Access Token（PAT），值应为 ghp_ / github_pat_ 等开头的一串令牌。
# 不要填写 ssh-ed25519 AAAA... 那是 SSH 公钥，用于 Deploy key，不能当作 HTTPS token。
# 服务器配置示例：git remote set-url origin https://github.com/<owner>/<repo>.git
# 拉取时可使用 GIT_ASKPASS 或 credential helper，避免把 token 写进仓库 .git/config 明文 URL。
# github_deploy_token=
